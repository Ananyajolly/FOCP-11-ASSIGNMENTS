#include <bits/stdc++.h>
using namespace std;

const int MAXN = 10000000;

int spf[MAXN + 1];

void sieve()
{
    for(int i = 2; i <= MAXN; i++)
    {
        if(spf[i] == 0)
        {
            spf[i] = i;

            if(1LL * i * i <= MAXN)
            {
                for(int j = i * i; j <= MAXN; j += i)
                {
                    if(spf[j] == 0)
                        spf[j] = i;
                }
            }
        }
    }
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    sieve();

    int T;
    cin >> T;

    while(T--)
    {
        int n;
        cin >> n;

        int distinct = 0;

        while(n > 1)
        {
            int p = spf[n];
            distinct++;

            while(n % p == 0)
                n /= p;
        }

        cout << (1 << distinct) << '\n';
    }

    return 0;
}
